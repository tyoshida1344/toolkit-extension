{
  "manifest_version": 3,
  "name": "便利ツール オールインワン",
  "version": "1.1.0",
  "description": "文字列生成・エポック変換・カラー変換・翻訳・メモ帳のオールインワンツール",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://translate.googleapis.com/*", "http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
